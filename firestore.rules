rules_version = '2';

// ════════════════════════════════════════════════════════════════════
// Firestore security rules for Ekta Padel.
//
// WHY THIS MATTERS: the app's admin check (window.isAdmin = email == ADMIN)
// is CLIENT-SIDE ONLY — it gates the UI, NOT the database. Without these
// rules, anyone could open the Firebase SDK/console and overwrite or wipe
// `padel/main` (every match ever recorded). These rules make the database
// itself enforce "only the admin may write".
//
// DEPLOY: Firebase Console → Firestore Database → Rules → paste → Publish.
//   (or `firebase deploy --only firestore:rules` if you use the CLI)
// ════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // The single admin allowed to modify the dataset. Matches the email used
    // by ADMIN_EMAIL in app.js. (Switch to a UID check — request.auth.uid ==
    // 'xxx' — if you prefer; email works fine for Google sign-in.)
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'ankit.konchady@gmail.com'
          && request.auth.token.email_verified == true;
    }

    // ── Leaderboard data (padel/main, padel/photos) ──
    // Public read (anyone can view the leaderboard); only the admin may write.
    // To make the data private instead, change `read` to `if request.auth != null`.
    match /padel/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Backups (backups/{YYYY-MM-DD}) ──
    // Admin only, both directions.
    match /backups/{doc} {
      allow read, write: if isAdmin();
    }

    // ── Client error reports (errors/{clientId}) ──
    // Any SIGNED-IN user may write their own error doc so real-world breakage
    // reaches the maintainer; only the admin may read/delete them. This is NOT
    // world-writable (requires auth), which keeps it from being a spam vector.
    // Trade-off: errors from signed-OUT viewers stay only in their localStorage.
    match /errors/{clientId} {
      allow read, delete: if isAdmin();
      allow create, update: if request.auth != null;
    }

    // ── Everything else: locked ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
